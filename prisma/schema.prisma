generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PARENT
  CHILD
}

enum RedemptionStatus {
  PENDING    // niño solicitó, esperando decisión del padre
  APPROVED   // padre aprobó, monedas descontadas
  REJECTED   // padre rechazó
}

enum TaskStatus {
  PENDING    // created, awaiting child action
  COMPLETED  // child marked done, awaiting parent approval
  APPROVED   // parent approved, coins awarded
  REJECTED   // parent rejected, back to PENDING
}

model User {
  id            String    @id
  name          String
  email         String?   @unique
  username      String?   @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  // Better Auth admin plugin
  role          String    @default("user")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  // Monedin
  familyRole    Role      @default(PARENT)

  // Better Auth
  sessions      Session[]
  accounts      Account[]

  // Relaciones Monedin
  childProfile      ChildProfile?  @relation("UserProfile")
  childrenProfiles  ChildProfile[] @relation("ParentChildren")
  tasks             Task[]         @relation("ParentTasks")
  rewards           Reward[]       @relation("ParentRewards")
}

model ChildProfile {
  id       String  @id @default(cuid())
  coins    Int     @default(0)
  age      Int?
  avatar   String?

  userId   String  @unique
  user     User    @relation("UserProfile", fields: [userId], references: [id], onDelete: Cascade)

  parentId String
  parent   User    @relation("ParentChildren", fields: [parentId], references: [id])

  tasks       Task[]
  redemptions RewardRedemption[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  coins       Int        @default(0)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  childId     String
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  parentId    String
  parent      User         @relation("ParentTasks", fields: [parentId], references: [id])
}

model Reward {
  id          String   @id @default(cuid())
  title       String
  description String?
  coins       Int      @default(0)
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parentId    String
  parent      User     @relation("ParentRewards", fields: [parentId], references: [id])

  redemptions RewardRedemption[]
}

model RewardRedemption {
  id        String            @id @default(cuid())
  status    RedemptionStatus  @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  rewardId  String
  reward    Reward       @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  childId   String
  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

// Tablas generadas por Better Auth (npx better-auth generate)
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}
