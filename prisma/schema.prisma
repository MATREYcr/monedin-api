generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PARENT
  CHILD
}

model User {
  id            String    @id
  name          String
  email         String?   @unique
  username      String?   @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  // Better Auth admin plugin
  role          String    @default("user")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  // Monedin
  familyRole    Role      @default(PARENT)

  // Better Auth
  sessions      Session[]
  accounts      Account[]

  // Relaciones Monedin
  childProfile      ChildProfile?  @relation("UserProfile")
  childrenProfiles  ChildProfile[] @relation("ParentChildren")
}

model ChildProfile {
  id       String  @id @default(cuid())
  coins    Int     @default(0)
  age      Int?
  avatar   String?

  userId   String  @unique
  user     User    @relation("UserProfile", fields: [userId], references: [id], onDelete: Cascade)

  parentId String
  parent   User    @relation("ParentChildren", fields: [parentId], references: [id])
}

// Tablas generadas por Better Auth (npx better-auth generate)
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}
